# Required for the companion to respond intelligently.
# Get one at https://aistudio.google.com/app/apikey (free tier is fine to start).
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash (free tier, good quality).
# Use gemini-2.5-pro for higher quality at higher cost when you upgrade.
GEMINI_MODEL=gemini-2.5-flash

# Backend port (Railway sets this automatically — only needed in local dev).
PORT=8080
